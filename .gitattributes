# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly declare text files (optional, but can be helpful)
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.sh text eol=lf
*.css text eol=lf
*.js text eol=lf
*.html text eol=lf
*.json text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Declare files that will always have LF line endings on checkout
*.sh eol=lf

# Denote binary files to prevent Git from changing them or showing diffs
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.whl binary
*.egg binary
*.so binary
*.dylib binary
*.pyc binary
*.pyo binary
